# O arquivo .env normalmente não é versionado, mas como esse é um projeto para ser utilizado como base para outros, o versionei e
# coloquei aqui algumas variáveis de ambiente que são comumente utilzadas em projetos Django e outras que são uma escolha pessoal

# django
DJANGO_SECRET_KEY=  
# gere uma secret key do django com copiando o seguinte código no terminal:
# $ python manage.py shell
# >>> from django.core.management.utils import get_random_secret_key
# >>> get_random_secret_key()
# >>> <secret_key>

DJANGO_DEBUG= # True, False
DJANGO_MODE= # development, production, test, sandbox

# database
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=

# email
EMAIL_PASSWORD=

# redis
REDIS_HOST=
REDIS_PORT=